generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  confirmed
  cancelled
  completed
  no_show
}

enum PaymentStatus {
  paid
  pending
  failed
}

enum PaymentType {
  full
  deposit
}

enum MembershipRole {
  owner
  manager
  staff
}

enum MediaType {
  logo
  hero
  gallery
}

model UserProfile {
  id                 String            @id @default(cuid())
  auth0UserId        String            @unique
  email              String            @unique
  displayName        String?
  isPlatformAdmin    Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  memberships        StudioMembership[]
  createdBlocks      AvailabilityBlock[] @relation("BlockCreator")
}

model Studio {
  id                 String            @id @default(cuid())
  slug               String            @unique
  name               String
  publicDisplayName  String
  timezone           String
  email              String
  phone              String
  address            String
  serviceArea        String
  about              String
  bookingPolicy      String
  cancellationPolicy String            @default("")
  arrivalInstructions String           @default("")
  parkingInfo        String            @default("")
  bookingLinkMode    String            @default("internal")
  externalBookingUrl String?
  isPublic           Boolean           @default(false)
  publishedAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  brandPrimaryColor  String            @default("#6c63ff")
  brandSecondaryColor String           @default("#191b2a")
  memberships        StudioMembership[]
  media              StudioMedia[]
  bookings           Booking[]
  blocks             AvailabilityBlock[]
}

model StudioMembership {
  id         String         @id @default(cuid())
  studioId    String
  userProfileId String
  role       MembershipRole
  createdAt  DateTime       @default(now())
  studio     Studio         @relation(fields: [studioId], references: [id], onDelete: Cascade)
  userProfile UserProfile   @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([studioId, userProfileId])
}

model StudioMedia {
  id         String    @id @default(cuid())
  studioId    String
  mediaType   MediaType
  label       String
  url         String
  altText     String
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  studio      Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)
}

model Booking {
  id                     String        @id @default(cuid())
  studioId               String
  stripePaymentIntentId  String        @unique
  stripeCheckoutSessionId String?
  service                String
  paymentType            PaymentType
  customerName           String
  customerEmail          String
  customerPhone          String
  startTime              DateTime
  endTime                DateTime
  timezone               String
  bookingStatus          BookingStatus @default(confirmed)
  paymentStatus          PaymentStatus @default(pending)
  amountTotal            Int
  amountDueNow           Int
  notes                  String        @default("")
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  studio                 Studio        @relation(fields: [studioId], references: [id], onDelete: Cascade)
}

model AvailabilityBlock {
  id             String      @id @default(cuid())
  studioId        String
  startTime       DateTime
  endTime         DateTime
  timezone        String
  reason          String
  createdByAdminId String?
  createdAt       DateTime    @default(now())
  studio          Studio      @relation(fields: [studioId], references: [id], onDelete: Cascade)
  createdByAdmin  UserProfile? @relation("BlockCreator", fields: [createdByAdminId], references: [id], onDelete: SetNull)
}

model StripeWebhookEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  type        String
  processedAt DateTime @default(now())
}
